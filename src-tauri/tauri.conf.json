{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tokengochi",
  "version": "0.1.0",
  "identifier": "com.tokengochi.app",
  "build": {
    "beforeDevCommand": "npm --prefix ui/overlay run build && npm --prefix ui/dashboard run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ui/overlay run build && npm --prefix ui/dashboard run build",
    "frontendDist": "../ui/dashboard/build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "/",
        "title": "tokengochi",
        "width": 800,
        "height": 600
      },
      {
        "label": "overlay",
        "url": "/overlay/index.html",
        "title": "tokengochi-overlay",
        "width": 1280,
        "height": 800,
        "x": 0,
        "y": 0,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "focus": false,
        "acceptFirstMouse": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["economy.toml"]
  }
}
